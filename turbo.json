{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "VERCEL",
    "VERCEL_URL",
    "VERCEL_ENV",
    "APP_HOST",
    "DATABASE_URL",
    "BETTER_AUTH_SECRET",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "UPLOADTHING_TOKEN",
    "FROM_EMAIL",
    "RESEND_API_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_SUB_READER",
    "STRIPE_SUB_COMPETE",
    "STRIPE_SUB_DOMINATE",
    "AZURE_API_KEY",
    "AZURE_RESOURCE_NAME",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "SHOPIFY_CLIENT_ID",
    "SHOPIFY_CLIENT_SECRET",
    "SHOPIFY_AUTHORIZATION_URL",
    "SHOPIFY_TOKEN_URL",
    "SENTRY_DSN",
    "NEXT_PUBLIC_SENTRY_DSN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "//#lint": {
      "cache": false
    },
    "outdated": {
      "cache": false,
      "interactive": true
    },
    "clean": {
      "cache": false
    }
  }
}

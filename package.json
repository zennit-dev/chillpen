{
  "name": "chillpen",
  "private": true,
  "author": {
    "name": "zennit",
    "email": "zennit.dev@gmail.com",
    "url": "https://www.zennit.dev/"
  },
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=./apps/web...",
    "build:mobile": "turbo run build --filter=./apps/mobile...",
    "build:packages": "turbo build --filter=@zenncore/*",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=./apps/web...",
    "dev:mobile": "turbo run dev --filter=./apps/mobile...",
    "dev:packages": "turbo dev --filter=@zenncore/*",
    "lint": "biome check --write",
    "typecheck": "turbo run typecheck",
    "outdated": "turbo run outdated && bun outdated -r",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@turbo/gen": "^2.6.3",
    "turbo": "^2.6.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.4",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "packages/shared/*",
      "packages/shared/config/*"
    ],
    "catalog": {
      "@hookform/resolvers": "^5.2.2",
      "@tailwindcss/postcss": "^4.1.18",
      "@types/node": "^24.10.3",
      "@types/react": "^19.2.7",
      "@types/react-dom": "^19.2.3",
      "react": "^19.2.3",
      "react-hook-form": "^7.68.0",
      "tailwindcss": "^4.1.18",
      "tsdown": "^0.22.2",
      "typescript": "^5.9.3",
      "zod": "^4.1.13"
    },
    "catalogs": {
      "mobile": {
        "@types/react": "~19.1.10",
        "expo": "^54.0.23",
        "nativewind": "^4.2.1",
        "react-native": "0.81.5",
        "react": "19.1.0",
        "typescript": "^5.9.3"
      }
    }
  },
  "dependencies": {
    "tsdown": "^0.22.2"
  }
}
